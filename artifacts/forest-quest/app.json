{
  "expo": {
    "name": "Forest Quest",
    "slug": "forest-quest",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "forest-quest",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a0e2e"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "backgroundColor": "#1a0e2e",
      "package": "com.johnosama.forestquest",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#1a0e2e"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "6781e794-562a-440f-baf1-9076946b6339"
      }
    },
    "owner": "johnosamas-organization"
  }
}
